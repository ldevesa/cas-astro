---
import Layout from '../layouts/Layout.astro';
import { getCasos, getCasoImage, getCasoImageAlt } from '../lib/wp';

const casos = await getCasos('es', 6);

const soluciones = [
  { icon: '/img/iconos/soluciones/1_experiencia.svg', text: 'Desarrollamos la experiencia del usuario dentro del espacio.' },
  { icon: '/img/iconos/soluciones/2_locales.svg',     text: 'Diseñamos externa e internamente los locales.' },
  { icon: '/img/iconos/soluciones/3_manual.svg',      text: 'Creamos un manual de aplicación de marca & experiencia del usuario en los locales.' },
  { icon: '/img/iconos/soluciones/4_instalacion.svg', text: 'Producimos e Instalamos desde la Marquesina hasta el mobiliario y todos los elementos de marca.' },
  { icon: '/img/iconos/soluciones/5_contenido.svg',   text: 'Generamos & Administramos el contenido.' },
  { icon: '/img/iconos/soluciones/6_folleteria.svg',  text: 'Desarrollamos & Producimos toda la folletería y elementos de comunicación dentro del local.' },
  { icon: '/img/iconos/soluciones/7_control.svg',     text: 'Controlamos que se cumplan todos los parámetros establecidos.' },
];
---

<Layout
  title="Trade Marketing y Puntos de Venta | CAS Contenidos Advertising"
  description="Desarrollamos soluciones integrales para puntos de venta y centros de atención al cliente, basándonos en 3 ejes: accesibilidad, espacios e interacción."
>

  <!-- Hero: imagen + texto -->
  <section class="bg-black">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">

      <!-- Imagen -->
      <div
        class="min-h-80 lg:min-h-screen bg-cover bg-center"
        style="background-image: url('/img/experiencia-venta.jpg')"
      ></div>

      <!-- Contenido -->
      <div class="flex items-center px-10 md:px-16 py-20">
        <div>
          <a href="/que-hacemos" class="inline-flex items-center gap-2 font-['Inter'] text-xs uppercase tracking-wider text-gray-500 hover:text-[#ffb876] transition-colors mb-10">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            Qué Hacemos
          </a>

          <h1 class="font-['Space_Grotesk'] font-black text-5xl md:text-6xl tracking-tighter leading-[0.9] text-[#F69220] mb-10">
            Trade Marketing<br />y Puntos de Venta
          </h1>

          <div class="space-y-5 font-['Plus_Jakarta_Sans'] text-white text-base leading-relaxed">
            <p>Un producto espectacular, de una excelente marca, con una muy buena comunicación y una mejor distribución puede desplomarse con una mala experiencia en el punto de venta.</p>
            <p>El Trade es el último eslabón de la cadena y uno de los fundamentales para lograr las ventas.</p>
            <p>Una mala exhibición, falta de comunicación o cualquiera otra falencia en el punto de venta puede lograr que un producto sea un fracaso.</p>
            <p>Desde CAS desarrollamos soluciones integrales para puntos de venta y centros de atención al cliente, basándonos en 3 ejes: <strong class="text-[#F69220]">accesibilidad, espacios e interacción.</strong></p>
            <p>Con nuestro equipo de especialistas creamos y ejecutamos todo el proceso: desde el análisis previo, la creatividad, el diseño de las piezas o elementos, la producción e instalación, hasta el posterior control de lo ejecutado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Soluciones -->
  <section class="bg-[#F69220] py-20">
    <div class="max-w-7xl mx-auto px-8">
      <h2 class="font-['Space_Grotesk'] font-black text-4xl md:text-5xl text-white tracking-tight mb-2">Soluciones <span class="text-black">.</span></h2>
      <p class="font-['Plus_Jakarta_Sans'] text-white/80 text-lg mb-14">Desarrollamos soluciones integrales para puntos de venta y centros de atención al cliente.</p>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {soluciones.map(s => (
          <div class="bg-white rounded-2xl p-6 flex flex-col gap-4">
            <img src={s.icon} alt="" class="w-12 h-12 object-contain" />
            <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-sm leading-relaxed">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3 ejes -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#26c6da] mb-4"><span class="font-light">1</span> . Accesibilidad</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed">Invitamos al público a <strong>conectar con la marca</strong> e interactuar con tus productos.</p>
        </div>
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#EA2227] mb-4"><span class="font-light">2</span> . Interacción</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed">La experiencia hace que <strong>el cliente se involucre</strong>, se lleve algo más que el producto y así se construye recordación de marca.</p>
        </div>
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#F69220] mb-4"><span class="font-light">3</span> . Espacios</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed"><strong>Creamos espacios</strong> para una vivencia total de la marca, con el mobiliario exacto para generar una experiencia única.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Proceso -->
  <section class="bg-[#f5f5f5] py-12 text-center border-y border-gray-200">
    <div class="max-w-3xl mx-auto px-8">
      <h4 class="font-['Space_Grotesk'] font-black text-2xl text-black tracking-tight">
        Brindamos una solución integral cubriendo todas las instancias del proceso:
      </h4>
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3">
    <div class="bg-[#26c6da] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">lightbulb</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Planificación</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">Estrategia y propuesta creativa de la acción.</p>
    </div>
    <div class="bg-[#F69220] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">polyline</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Implementación</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">Producción, instalación y desarrollo de la acción.</p>
    </div>
    <div class="bg-[#EA2227] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">photo_camera</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Control</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">Para el control y monitoreo de la acción, en toda la región.</p>
    </div>
  </section>

  <!-- Casos de éxito -->
  <section class="bg-black py-24">
    <div class="max-w-screen-2xl mx-auto px-8">
      <h2 class="font-['Space_Grotesk'] font-black text-5xl md:text-7xl tracking-tight text-white text-center mb-16">
        Casos de Éxito <span class="text-[#F69220]">.</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {casos.map(caso => (
          <a href={`/casos/${caso.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-4/3 rounded-2xl mb-4">
              <img
                alt={getCasoImageAlt(caso)}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                src={getCasoImage(caso)}
                loading="lazy"
              />
              <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <span class="font-['Space_Grotesk'] font-bold text-white text-sm uppercase tracking-widest">Ver caso</span>
              </div>
            </div>
            <h3 class="font-['Space_Grotesk'] font-bold text-lg text-white group-hover:text-[#ffb876] transition-colors tracking-tight" set:html={caso.title.rendered} />
          </a>
        ))}
      </div>
      <div class="text-center mt-16">
        <a href="/casos" class="inline-block border border-white/20 text-white font-['Space_Grotesk'] font-black uppercase tracking-widest px-12 py-5 hover:bg-white hover:text-black transition-all duration-300">
          Ver todos los casos
        </a>
      </div>
    </div>
  </section>

</Layout>
