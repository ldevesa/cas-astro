---
import Layout from '../layouts/Layout.astro';
import { getCasos, getCasoImage, getCasoImageAlt } from '../lib/wp';
import ClientesCarousel from '../components/ClientesCarousel.astro';
import HeroShader from '../components/HeroShader.astro';
import CoberturaGlobo from '../components/CoberturaGlobo.astro';

const casos = await getCasos('es', 6);
---

<Layout
  title="CAS | Conectamos marcas con consumidores a través de experiencias memorables"
  description="Conectamos marcas con consumidores a través de experiencias memorables"
>

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="relative h-screen w-full flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-60">
      <HeroShader />
      <div class="absolute inset-0 bg-linear-to-b from-black/40 via-transparent to-[#131313]"></div>
    </div>
    <div class="relative z-10 container mx-auto px-8 text-center">
      <h1 class="font-['Space_Grotesk'] font-black text-2xl md:text-[3.33rem] leading-[0.85] tracking-[-0.06em] text-white" style="text-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        Somos especialistas en innovación OOH & brand experience. Conectamos marcas con audiencias a través de experiencias memorables.
      </h1>
    </div>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
      <span class="material-symbols-outlined text-white/40 text-4xl">south</span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CONSUMER ATTENTION
  ══════════════════════════════════════════════ -->
  <section class="w-full bg-[#131313]">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[80vh] lg:min-h-screen">
      <div class="relative min-h-80 lg:min-h-screen overflow-hidden">
        <img
          alt="Consumidor en entorno urbano"
          class="w-full h-full object-cover"
          src="/img/fiesta.webp"
        />
        <div class="absolute inset-0 bg-linear-to-r from-black/50 via-black/20 to-transparent"></div>
      </div>
      <div class="relative bg-[#F69220] text-white px-7 md:px-10 lg:px-12 xl:px-16 py-10 md:py-12 lg:py-14 flex items-center">
        <div class="w-full">
          <h2 class="font-['Space_Grotesk'] font-black text-[clamp(2rem,4vw,5rem)] leading-[0.95] tracking-tight mb-7 md:mb-8">
            Captar la atención del consumidor .
          </h2>
          <div class="space-y-5 md:space-y-6 font-['Plus_Jakarta_Sans'] text-[clamp(1rem,1.32vw,1.9rem)] leading-[1.3]">
            <p>La comunicación cambió porque nosotros cambiamos, ya no somos los mismos. Seguir comunicando igual que hace 10 años sería un gran error para cualquier marca.</p>
            <p>Hoy más que nunca se necesitan <strong>ideas excepcionales</strong>, distintas, entretenidas, emocionantes, impactantes y valientes para capturar la mente del consumidor.</p>
            <p>La preferencia de las marcas ya no se basa en un spot de TV, hoy <strong>el principal driver es el producto en sí y las experiencias</strong>. Pero <strong>la clave no es solo la idea sino también la ejecución</strong> en todos los puntos de contacto en donde el consumidor se encuentra con la marca.</p>
            <p>En CAS proponemos ir más allá de lo tradicional, pensamos grandes ideas para <strong>conectar a las marcas con los consumidores a través de experiencias reales</strong>, que luego continúan expandiéndose en el mundo on line y en el resto de los sistemas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SERVICIOS INTERACTIVOS
  ══════════════════════════════════════════════ -->
  <section class="relative min-h-screen w-full overflow-hidden bg-black flex flex-col justify-center items-center py-24" id="services-interactive">
    <!-- Backgrounds dinámicos -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[#131313] transition-opacity duration-700 opacity-100" id="bg-default">
        <img alt="" class="w-full h-full object-cover opacity-30" src="/img/fiesta.webp" />
      </div>
      <div class="service-bg absolute inset-0 bg-[#F69220] transition-opacity duration-500 opacity-0 pointer-events-none" id="bg-experience">
        <video muted loop playsinline preload="none" class="w-full h-full object-cover mix-blend-multiply opacity-60">
          <source src="/video/experience.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="service-bg absolute inset-0 bg-[#F69220] transition-opacity duration-500 opacity-0 pointer-events-none" id="bg-trade">
        <video muted loop playsinline preload="none" class="w-full h-full object-cover mix-blend-multiply opacity-60">
          <source src="/video/trade.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="service-bg absolute inset-0 bg-[#F69220] transition-opacity duration-500 opacity-0 pointer-events-none" id="bg-digital">
        <video muted loop playsinline preload="none" class="w-full h-full object-cover mix-blend-overlay opacity-60">
          <source src="/video/digital.mp4" type="video/mp4" />
        </video>
      </div>
      <div class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-black/80 z-1"></div>
    </div>

    <!-- Contenido -->
    <div class="relative z-10 w-full max-w-6xl px-8 text-center">
      <p class="font-['Inter'] text-xs uppercase tracking-[0.4em] text-[#ffb876] mb-16 opacity-60">Qué Hacemos</p>
      <ul class="flex flex-col items-center gap-2">
        <a href="/experiencia-de-marca" class="service-item-trigger group py-4 w-full border-b border-white/10 block" data-target="bg-experience">
          <div class="flex items-center justify-between max-w-4xl mx-auto px-4">
            <span class="font-['Space_Grotesk'] text-5xl md:text-8xl font-bold tracking-tighter text-white/40 group-hover:text-white transition-all duration-500 group-hover:translate-x-4">Experience</span>
            <div class="opacity-0 group-hover:opacity-100 transition-all duration-500 text-right">
              <span class="font-['Inter'] text-xs uppercase tracking-[0.3em] text-[#F69220] block mb-1">01</span>
              <p class="font-['Plus_Jakarta_Sans'] text-sm text-white/60 max-w-xs">Realidades inmersivas físicas y digitales que redefinen la interacción humana.</p>
            </div>
          </div>
        </a>
        <a href="/trade-marketing" class="service-item-trigger group py-4 w-full border-b border-white/10 block" data-target="bg-trade">
          <div class="flex items-center justify-between max-w-4xl mx-auto px-4">
            <span class="font-['Space_Grotesk'] text-5xl md:text-8xl font-bold tracking-tighter text-white/40 group-hover:text-white transition-all duration-500 group-hover:translate-x-4">Trade</span>
            <div class="opacity-0 group-hover:opacity-100 transition-all duration-500 text-right">
              <span class="font-['Inter'] text-xs uppercase tracking-[0.3em] text-[#EA2227] block mb-1">02</span>
              <p class="font-['Plus_Jakarta_Sans'] text-sm text-white/60 max-w-xs">Estrategias comerciales de alta velocidad que disruptan el equilibrio del mercado.</p>
            </div>
          </div>
        </a>
        <a href="/carteleria" class="service-item-trigger group py-4 w-full block" data-target="bg-digital">
          <div class="flex items-center justify-between max-w-4xl mx-auto px-4">
            <span class="font-['Space_Grotesk'] text-5xl md:text-8xl font-bold tracking-tighter text-white/40 group-hover:text-white transition-all duration-500 group-hover:translate-x-4">Digital</span>
            <div class="opacity-0 group-hover:opacity-100 transition-all duration-500 text-right">
              <span class="font-['Inter'] text-xs uppercase tracking-[0.3em] text-[#F69220] block mb-1">03</span>
              <p class="font-['Plus_Jakarta_Sans'] text-sm text-white/60 max-w-xs">Arquitectura next-gen para la web descentralizada y conectada.</p>
            </div>
          </div>
        </a>
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       NOSOTROS
  ══════════════════════════════════════════════ -->
  <section class="bg-surface-lowest py-32 border-y border-white/5" id="nosotros">
    <div class="max-w-screen-2xl mx-auto px-8">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">

        <!-- Texto principal -->
        <div>
          <p class="font-['Inter'] text-xs uppercase tracking-[0.4em] text-[#ffb876] mb-6">Quiénes somos</p>
          <h2 class="font-['Space_Grotesk'] font-black text-5xl md:text-7xl tracking-tighter leading-[0.9] text-white mb-10">
            Somos CAS.
          </h2>
          <div class="space-y-6 font-['Plus_Jakarta_Sans'] text-gray-400 text-lg leading-relaxed">
            <p>
              Somos una agencia de comunicación especializada en <strong class="text-white">experiencias de marca, trade marketing y cartelería digital</strong>. Trabajamos con las marcas más exigentes del mundo para crear momentos que la gente recuerda.
            </p>
            <p>
              Nacimos en Buenos Aires y hoy operamos con equipos propios en <strong class="text-white">Argentina, México, España y Estados Unidos</strong>. Esa presencia regional nos permite ejecutar proyectos de escala global con conocimiento local.
            </p>
            <p>
              No tercerizamos la creatividad ni la producción. Todo nace y se ejecuta dentro de CAS, lo que nos da control total sobre cada detalle de cada proyecto.
            </p>
          </div>
        </div>

        <!-- Equipo / números -->
        <div class="flex flex-col gap-6">

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4">
            {[
              { num: '+25', label: 'Años de experiencia' },
              { num: '+38', label: 'Marcas en cartera' },
              { num: '4', label: 'Oficinas propias' },
              { num: '3', label: 'Disciplinas integradas' },
            ].map(stat => (
              <div class="bg-[#131313] border border-white/5 rounded-2xl p-8">
                <p class="font-['Space_Grotesk'] font-black text-5xl text-[#F69220] tracking-tight mb-1">{stat.num}</p>
                <p class="font-['Inter'] text-xs uppercase tracking-wider text-gray-500">{stat.label}</p>
              </div>
            ))}
          </div>

          <!-- Perfiles del equipo -->
          <div class="bg-[#131313] border border-white/5 rounded-2xl p-8">
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-white mb-6 uppercase tracking-widest">Nuestro equipo</h3>
            <div class="flex flex-col gap-4">
              {[
                { area: 'Estrategia & Cuentas', desc: 'Directores de marca y planners que entienden el negocio del cliente.' },
                { area: 'Creatividad', desc: 'Directores de arte, diseñadores y conceptualistas.' },
                { area: 'Producción', desc: 'Productores, proveedores y técnicos especializados.' },
                { area: 'Tecnología', desc: 'Desarrolladores e integradores de sistemas digitales.' },
              ].map(perfil => (
                <div class="flex gap-4 items-start pb-4 border-b border-white/5 last:border-0 last:pb-0">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[#F69220] shrink-0"></span>
                  <div>
                    <p class="font-['Space_Grotesk'] font-bold text-white text-sm">{perfil.area}</p>
                    <p class="font-['Plus_Jakarta_Sans'] text-gray-500 text-sm mt-0.5">{perfil.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CASOS
  ══════════════════════════════════════════════ -->
  <section class="bg-[#131313] py-32" id="casos">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
        <div>
          <p class="font-['Inter'] text-xs uppercase tracking-[0.35em] text-[#ffb876] mb-4">Work</p>
          <h2 class="font-['Space_Grotesk'] text-4xl md:text-6xl font-black tracking-tight text-white leading-[0.95]">Casos</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="cases-grid">
        {casos.map(caso => (
          <a href={`/casos/${caso.slug}`} class="case-card group block">
            <div class="relative overflow-hidden aspect-4/3 rounded-2xl mb-6">
              <img
                alt={getCasoImageAlt(caso)}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                src={getCasoImage(caso)}
                loading="lazy"
              />
            </div>
            <div class="space-y-2">
              <h3
                class="font-['Space_Grotesk'] text-2xl font-bold tracking-tight text-white group-hover:text-[#ffb876] transition-colors"
                set:html={caso.title.rendered}
              />
              {caso.excerpt.rendered && (
                <p
                  class="text-on-surface-variant text-sm font-['Plus_Jakarta_Sans'] line-clamp-2"
                  set:html={caso.excerpt.rendered}
                />
              )}
            </div>
          </a>
        ))}
      </div>

      <div class="mt-20 text-center">
        <a class="inline-block bg-white text-black font-['Space_Grotesk'] font-black uppercase tracking-widest px-12 py-5 hover:bg-[#ffb876] transition-all duration-300" href="/casos">Ver todos los casos</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       COBERTURA GLOBAL (Globo)
  ══════════════════════════════════════════════ -->
  <CoberturaGlobo />

  <!-- ══════════════════════════════════════════════
       CLIENTES (Carousel marquee)
  ══════════════════════════════════════════════ -->
  <ClientesCarousel />

  <!-- ══════════════════════════════════════════════
       CONTACTO + MAPA
  ══════════════════════════════════════════════ -->
  <section class="bg-[#131313] py-20 md:py-24 border-y border-outline-variant/10">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
        <aside class="rounded-2xl border border-white/10 bg-[#111111] p-8 md:p-10 flex flex-col justify-between">
          <div>
            <p class="font-['Inter'] text-xs uppercase tracking-[0.35em] text-[#ffb876] mb-4">Contacto</p>
            <h3 class="font-['Space_Grotesk'] text-4xl md:text-5xl font-black tracking-tight leading-[0.95] text-white">¡Déjanos tu mensaje!</h3>
            <p class="mt-6 text-on-surface-variant font-['Plus_Jakarta_Sans'] text-lg">Estamos en Esteban Echeverria 760, B1603 Villa Martelli, Provincia de Buenos Aires.</p>
          </div>
          <div class="mt-10 flex flex-col sm:flex-row lg:flex-col gap-4">
            <a class="inline-flex justify-center items-center bg-[#ffb876] text-on-primary font-['Space_Grotesk'] font-black uppercase tracking-[0.08em] px-8 py-4 rounded-xl hover:brightness-110 transition-all" href="#contacto-footer">Contactanos</a>
            <a class="inline-flex justify-center items-center border border-white/20 text-white font-['Space_Grotesk'] font-bold uppercase tracking-[0.08em] px-8 py-4 rounded-xl hover:bg-white hover:text-black transition-all" href="https://maps.google.com/?q=Esteban+Echeverria+760,+B1603+Villa+Martelli,+Provincia+de+Buenos+Aires" rel="noopener" target="_blank">Ver en Google Maps</a>
          </div>
        </aside>
        <div class="rounded-2xl border border-white/10 bg-[#111111] overflow-hidden p-3 md:p-4">
          <div class="relative w-full h-105 md:h-130 rounded-xl overflow-hidden">
            <img alt="Mapa de ubicacion de CAS" class="w-full h-full object-cover" loading="lazy" src="/assets/maps/contacto.svg" />
            <div class="absolute left-[50.03%] top-[49.8%] -translate-x-1/2 -translate-y-full pointer-events-none">
              <div class="relative flex items-center justify-center">
                <span class="absolute w-10 h-10 rounded-full bg-[#F69220]/25 animate-ping"></span>
                <span class="absolute w-6 h-6 rounded-full bg-[#F69220]/40"></span>
                <span class="w-4 h-4 rounded-full bg-[#F69220] border-2 border-[#111111]"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CAREERS CTA
  ══════════════════════════════════════════════ -->
  <section class="relative py-20 md:py-28 border-y border-white/10 overflow-hidden">
    <img alt="Equipo CAS en activacion" class="absolute inset-0 w-full h-full object-cover" loading="lazy" src="/img/fiesta.webp" />
    <div class="absolute inset-0 bg-[#090909]/70"></div>
    <div class="absolute inset-0 bg-linear-to-r from-[#0c0c0c]/75 via-[#0c0c0c]/45 to-[#0c0c0c]/75"></div>
    <div class="relative z-10 max-w-screen-2xl mx-auto px-8 text-center">
      <h3 class="font-['Space_Grotesk'] text-4xl md:text-6xl font-black tracking-tight leading-[0.95] text-white">Conocé los puestos disponibles</h3>
      <a
        class="mt-10 inline-flex items-center justify-center rounded-full px-10 py-4 text-white font-['Space_Grotesk'] text-2xl md:text-4xl font-bold bg-linear-to-r from-[#f5a623] to-[#f15a49] hover:brightness-110 transition-all"
        style="box-shadow: 0 0 35px rgba(246,146,32,0.45);"
        href="https://contenidosad.com/careers/"
        rel="noopener"
        target="_blank"
      >¡Sumate al equipo!</a>
    </div>
  </section>

</Layout>


<script>
  // Service hover backgrounds — carga y reproduce video solo al hacer hover
  // astro:page-load dispara tanto en la carga inicial como en navegaciones con View Transitions
  function initServiceHover() {
    const triggers = document.querySelectorAll('.service-item-trigger');
    const backgrounds = document.querySelectorAll<HTMLElement>('.service-bg');
    const defaultBg = document.getElementById('bg-default');
    if (!triggers.length) return;

    triggers.forEach(trigger => {
      trigger.addEventListener('mouseenter', () => {
        const targetId = trigger.getAttribute('data-target');
        backgrounds.forEach(bg => {
          const video = bg.querySelector('video');
          if (bg.id === targetId) {
            bg.classList.replace('opacity-0', 'opacity-100');
            if (video) video.play().catch(() => {});
          } else {
            bg.classList.replace('opacity-100', 'opacity-0');
            if (video) {
              video.play().then(() => video.pause()).catch(() => {});
            }
          }
        });
        defaultBg?.classList.replace('opacity-100', 'opacity-0');
      });
      trigger.addEventListener('mouseleave', () => {
        backgrounds.forEach(bg => {
          bg.classList.replace('opacity-100', 'opacity-0');
          const video = bg.querySelector('video');
          if (video) video.play().then(() => video.pause()).catch(() => {});
        });
        defaultBg?.classList.replace('opacity-0', 'opacity-100');
      });
    });
  }

  document.addEventListener('astro:page-load', initServiceHover);
</script>
