---
import Layout from '../layouts/Layout.astro';
import { getStaticSiteData } from '../lib/wp';

const { offices } = getStaticSiteData();
---

<Layout
  title="Contacto | CAS Contenidos Advertising"
  description="Contactate con CAS. Oficinas en Buenos Aires, Ciudad de México, Madrid y Miami."
>

  <!-- Hero -->
  <section class="bg-[#0a0a0a] pt-16 pb-20 border-b border-white/5">
    <div class="max-w-screen-2xl mx-auto px-8">
      <p class="font-['Inter'] text-xs uppercase tracking-[0.4em] text-[#ffb876] mb-4">Estemos en contacto</p>
      <h1 class="font-['Space_Grotesk'] font-black text-6xl md:text-9xl tracking-tighter leading-[0.9] text-white">
        Contacto
      </h1>
    </div>
  </section>

  <!-- Contenido principal -->
  <section class="bg-[#131313] py-24">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Formulario -->
        <div>
          <h2 class="font-['Space_Grotesk'] font-black text-3xl text-white tracking-tight mb-2">Contanos tu proyecto</h2>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-400 mb-10">Te respondemos en menos de 24 horas hábiles.</p>

          <form
            id="contact-form"
            class="flex flex-col gap-6"
          >
            <input type="hidden" name="_to" value="info@contenidosad.com" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Nombre *</label>
                <input
                  type="text"
                  name="nombre"
                  required
                  class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors"
                  placeholder="Tu nombre"
                />
              </div>
              <div>
                <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Empresa</label>
                <input
                  type="text"
                  name="empresa"
                  class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors"
                  placeholder="Nombre de tu empresa"
                />
              </div>
            </div>

            <div>
              <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Email *</label>
              <input
                type="email"
                name="email"
                required
                class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors"
                placeholder="tu@email.com"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Teléfono</label>
                <input type="tel" name="telefono" class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors" placeholder="+54 11 0000-0000" />
              </div>
              <div>
                <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Cargo</label>
                <input type="text" name="cargo" class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors" placeholder="Tu cargo" />
              </div>
            </div>

            <div>
              <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">País</label>
              <input type="text" name="pais" class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors" placeholder="Tu país" />
            </div>

            <div>
              <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">¿Qué necesitás?</label>
              <select
                name="servicio"
                class="w-full bg-[#1a1a1a] border border-white/10 text-gray-400 font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors"
              >
                <option value="">Seleccioná un servicio</option>
                <option value="experiencia">Experiencia de Marca</option>
                <option value="trade">Trade Marketing y Puntos de Venta</option>
                <option value="digital">Cartelería Digital</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <div>
              <label class="block font-['Inter'] text-xs uppercase tracking-wider text-gray-500 mb-2">Mensaje *</label>
              <textarea
                name="mensaje"
                required
                rows="5"
                class="w-full bg-[#1a1a1a] border border-white/10 text-white font-['Plus_Jakarta_Sans'] px-4 py-3 rounded-xl focus:outline-none focus:border-[#F69220] transition-colors resize-none"
                placeholder="Contanos sobre tu proyecto..."
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-[#F69220] text-white font-['Space_Grotesk'] font-black uppercase tracking-widest py-4 rounded-xl hover:brightness-110 transition-all duration-300 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Enviar mensaje
            </button>
            <p id="form-msg" class="hidden text-sm font-['Plus_Jakarta_Sans'] text-center"></p>
          </form>
        </div>

        <!-- Info de contacto -->
        <div class="flex flex-col gap-12">

          <!-- Oficinas -->
          <div>
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-white uppercase tracking-widest mb-8">Nuestras oficinas</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {offices.map(office => (
                <div class="bg-[#111111] border border-white/5 rounded-2xl p-6 hover:border-[#F69220]/30 transition-colors duration-300">
                  <p class="font-['Space_Grotesk'] text-xs uppercase tracking-[0.2em] text-[#ffb876] mb-2">{office.city}</p>
                  <p class="font-['Plus_Jakarta_Sans'] text-gray-400 text-sm leading-relaxed">{office.address}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Email directo -->
          <div class="bg-[#111111] border border-white/5 rounded-2xl p-8">
            <h3 class="font-['Space_Grotesk'] font-black text-xl text-white mb-4">Contacto directo</h3>
            <div class="flex flex-col gap-4">
              <a
                href="mailto:info@contenidosad.com"
                class="flex items-center gap-3 font-['Plus_Jakarta_Sans'] text-gray-400 hover:text-[#ffb876] transition-colors group"
              >
                <span class="material-symbols-outlined text-xl text-[#F69220]">mail</span>
                info@contenidosad.com
              </a>
              <a
                href="https://www.linkedin.com/company/contenidosad/"
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 font-['Plus_Jakarta_Sans'] text-gray-400 hover:text-[#ffb876] transition-colors"
              >
                <span class="material-symbols-outlined text-xl text-[#F69220]">open_in_new</span>
                LinkedIn
              </a>
              <a
                href="https://www.instagram.com/contenidos.ad"
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 font-['Plus_Jakarta_Sans'] text-gray-400 hover:text-[#ffb876] transition-colors"
              >
                <span class="material-symbols-outlined text-xl text-[#F69220]">photo_camera</span>
                Instagram
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const msg  = document.getElementById('form-msg') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    msg.className = 'hidden';

    const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
    const json = await res.json();

    if (json.ok) {
      msg.textContent = '¡Mensaje enviado! Te respondemos pronto.';
      msg.className = 'text-sm font-[\'Plus_Jakarta_Sans\'] text-center text-green-400';
      form.reset();
      btn.textContent = 'Enviar mensaje';
      btn.disabled = false;
      setTimeout(() => { window.location.href = '/gracias'; }, 3000);
    } else {
      msg.textContent = json.error ?? 'Hubo un error. Intentá de nuevo.';
      msg.className = 'text-sm font-[\'Plus_Jakarta_Sans\'] text-center text-red-400';
      btn.textContent = 'Enviar mensaje';
      btn.disabled = false;
    }
  });
</script>
