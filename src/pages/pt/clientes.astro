---
import Layout from '../../layouts/Layout.astro';
import { getClientes, getClienteLogo } from '../../lib/wp';

const clientes = await getClientes('pt');
---

<Layout
  title="Clientes | CAS Contenidos Advertising"
  description="As marcas que confiam na CAS para criar experiências memoráveis."
>

  <section class="bg-[#0a0a0a] pt-16 pb-20 border-b border-white/5">
    <div class="max-w-screen-2xl mx-auto px-8">
      <p class="font-['Inter'] text-xs uppercase tracking-[0.4em] text-[#ffb876] mb-4">Quem confia em nós</p>
      <h1 class="font-['Space_Grotesk'] font-black text-6xl md:text-9xl tracking-tighter leading-[0.9] text-white">Clientes</h1>
    </div>
  </section>

  <section class="bg-[#131313] py-24">
    <div class="max-w-screen-2xl mx-auto px-8">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
        {clientes.map(cliente => {
          const logo = getClienteLogo(cliente);
          if (!logo) return null;
          return (
            <div class="group flex items-center justify-center aspect-square bg-[#111111] border border-white/5 rounded-2xl p-6 hover:border-white/20 transition-all duration-300">
              <img
                src={logo}
                alt={cliente.title.rendered}
                class="w-full h-full object-contain filter grayscale group-hover:grayscale-0 opacity-50 group-hover:opacity-100 transition-all duration-300"
                loading="lazy"
              />
            </div>
          );
        })}
      </div>
    </div>
  </section>

</Layout>
