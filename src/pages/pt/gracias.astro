---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Obrigado! | CAS" description="Mensagem recebida.">
  <section class="bg-[#131313] min-h-screen flex items-center justify-center px-8">
    <div class="text-center max-w-lg">
      <span class="material-symbols-outlined text-6xl text-[#F69220] mb-6 block">check_circle</span>
      <h1 class="font-['Space_Grotesk'] font-black text-5xl md:text-6xl tracking-tight text-white leading-[0.95] mb-6">Obrigado!</h1>
      <p class="font-['Plus_Jakarta_Sans'] text-gray-400 text-lg leading-relaxed mb-10">
        Recebemos sua mensagem. Responderemos em menos de 24 horas úteis.
      </p>
      <a href="/pt/" class="inline-block bg-[#F69220] text-white font-['Space_Grotesk'] font-black uppercase tracking-widest px-10 py-4 rounded-xl hover:brightness-110 transition-all duration-300">
        Voltar ao início
      </a>
    </div>
  </section>
</Layout>
