---
import Layout from '../../layouts/Layout.astro';

const services = [
  {
    id: 'experience',
    num: '01',
    label: 'Experience',
    title: 'Experiência de Marca',
    href: '/pt/experiencia-de-marca',
    color: '#F69220',
    description: 'Criamos momentos que as pessoas querem viver e compartilhar. Desenvolvemos ativações, eventos e experiências imersivas que conectam emocionalmente as marcas com seus públicos no mundo real.',
    bullets: [
      'Ativações e eventos BTL',
      'Instalações imersivas e interativas',
      'Pop-ups e espaços de marca',
      'Lançamentos de produto',
      'Experiências no ponto de venda',
    ],
    video: '/video/experience.mp4',
  },
  {
    id: 'trade',
    num: '02',
    label: 'Trade',
    title: 'Trade Marketing e Pontos de Venda',
    href: '/pt/trade-marketing',
    color: '#EA2227',
    description: 'Transformamos cada ponto de contato comercial em uma oportunidade de conexão. Desenvolvemos estratégias e materiais que impulsionam a decisão de compra e fortalecem a presença de marca no canal.',
    bullets: [
      'Design e produção de materiais POP',
      'Estratégia de exibição e merchandising',
      'Treinamento e ativação de canais',
      'Programas de incentivos para a força de vendas',
      'Auditoria e acompanhamento no ponto de venda',
    ],
    video: '/video/trade.mp4',
  },
  {
    id: 'digital',
    num: '03',
    label: 'Digital',
    title: 'Comunicação Visual Digital',
    href: '/pt/carteleria',
    color: '#F69220',
    description: 'Levamos a comunicação visual ao próximo nível. Desenvolvemos e implementamos soluções de sinalização digital que elevam a experiência em espaços físicos, desde telas individuais até redes de centenas de displays.',
    bullets: [
      'Design de conteúdo para telas digitais',
      'Instalação e gestão de redes de digital signage',
      'Software de gestão de conteúdo (CMS)',
      'Integração com dados em tempo real',
      'Manutenção e suporte técnico',
    ],
    video: '/video/digital.mp4',
  },
];
---

<Layout
  title="O que fazemos | CAS Contenidos Advertising"
  description="Experiência de Marca, Trade Marketing e Comunicação Visual Digital. Conectamos marcas com consumidores através de experiências memoráveis."
>

  <section class="relative min-h-[60vh] flex items-end pb-20 overflow-hidden bg-black">
    <div class="absolute inset-0">
      <video autoplay muted loop playsinline class="w-full h-full object-cover opacity-30">
        <source src="/video/experience.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-linear-to-t from-black via-black/60 to-black/30"></div>
    </div>
    <div class="relative z-10 max-w-screen-2xl mx-auto px-8 w-full">
      <p class="font-['Inter'] text-xs uppercase tracking-[0.4em] text-[#ffb876] mb-4">O que fazemos</p>
      <h1 class="font-['Space_Grotesk'] font-black text-6xl md:text-9xl tracking-tighter leading-[0.9] text-white">O que<br />fazemos</h1>
    </div>
  </section>

  <section class="bg-[#131313] py-20 border-b border-white/5">
    <div class="max-w-screen-2xl mx-auto px-8">
      <p class="font-['Plus_Jakarta_Sans'] text-xl md:text-2xl text-gray-300 leading-relaxed max-w-3xl">
        Na CAS trabalhamos em três disciplinas que se complementam para criar
        ecossistemas de comunicação completos. Cada projeto integra estratégia,
        criatividade e execução de primeiro nível.
      </p>
    </div>
  </section>

  {services.map((s, i) => (
    <section class={`${i % 2 === 0 ? 'bg-surface-lowest' : 'bg-[#131313]'} py-24 border-b border-white/5`} id={s.id}>
      <div class="max-w-screen-2xl mx-auto px-8">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center ${i % 2 !== 0 ? 'lg:[direction:rtl]' : ''}`}>
          <div class="relative aspect-video rounded-2xl overflow-hidden lg:[direction:ltr]">
            <video autoplay muted loop playsinline class="w-full h-full object-cover">
              <source src={s.video} type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-6 left-6">
              <span class="font-['Inter'] text-xs uppercase tracking-[0.4em]" style={`color: ${s.color}`}>{s.num}</span>
              <p class="font-['Space_Grotesk'] font-black text-4xl text-white tracking-tighter">{s.label}</p>
            </div>
          </div>
          <div class="lg:[direction:ltr]">
            <h2 class="font-['Space_Grotesk'] font-black text-4xl md:text-5xl tracking-tight leading-[0.95] text-white mb-6">{s.title}</h2>
            <p class="font-['Plus_Jakarta_Sans'] text-lg text-gray-400 leading-relaxed mb-10">{s.description}</p>
            <ul class="flex flex-col gap-3 mb-10">
              {s.bullets.map(b => (
                <li class="flex items-start gap-3 font-['Plus_Jakarta_Sans'] text-gray-300 text-sm">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style={`background: ${s.color}`}></span>
                  {b}
                </li>
              ))}
            </ul>
            <a href={s.href} class="inline-flex items-center gap-2 font-['Space_Grotesk'] font-bold text-sm uppercase tracking-widest hover:gap-4 transition-all duration-300" style={`color: ${s.color}`}>
              Saiba mais <span class="material-symbols-outlined text-base">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  ))}

  <section class="bg-[#F69220] py-24">
    <div class="max-w-screen-2xl mx-auto px-8 text-center">
      <h2 class="font-['Space_Grotesk'] font-black text-5xl md:text-7xl tracking-tighter text-white leading-[0.9] mb-10">
        Tem um projeto<br />em mente?
      </h2>
      <a href="/pt/contacto" class="inline-block bg-black text-white font-['Space_Grotesk'] font-black uppercase tracking-widest px-12 py-5 hover:bg-white hover:text-black transition-all duration-300">
        Vamos conversar
      </a>
    </div>
  </section>

</Layout>
