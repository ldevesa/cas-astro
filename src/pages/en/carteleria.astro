---
import Layout from '../../layouts/Layout.astro';
import { getCasos, getCasoImage, getCasoImageAlt } from '../../lib/wp';

const casos = await getCasos('en', 6);

const capabilities = [
  { icon: '/img/iconos/carteleria/1_fotos.svg',        text: 'Create groups (playlists) of videos and images.' },
  { icon: '/img/iconos/carteleria/2_clima.svg',        text: 'Discriminate content on each screen by weather and time.' },
  { icon: '/img/iconos/carteleria/3_segmentacion.svg', text: 'Segment by location or device type.' },
  { icon: '/img/iconos/carteleria/4_control.svg',      text: 'Monitor each screen\'s operation, with alerts in case of errors.' },
  { icon: '/img/iconos/carteleria/5_dividir.svg',      text: 'Split the screen and display different content.' },
];

const sectors = [
  {
    title: 'Retail',
    img: '/img/carteleria/retail.jpg',
    reverse: false,
    text: "Capturing consumer attention at the point of sale is key to generating more sales, but achieving this is increasingly difficult due to the amount of stimuli they're exposed to inside a store.\n\nFor this reason, it is essential to generate a connection with what they are most accustomed to seeing: screens. Whether in your own store or competing with other brands, the key is the screen and what you communicate on it.\n\nCAS helps you identify opportunities and take advantage of them. We are experts in content generation and management at points of sale. We segment by store, screen type, support location, and more.",
  },
  {
    title: 'Banking',
    img: '/img/carteleria/banking.jpg',
    reverse: true,
    text: "Give your clients the real-time information they need to have the best experience during their bank visit.\n\nWith our content management service, we keep screens updated and manage all content to optimize communication between the bank and its clients.\n\nWe combine central bank notifications and bank-specific content with communication materials and ad hoc content creation to deliver material that complies with regulations, communicates, and entertains your clients.",
  },
  {
    title: 'Fast Food',
    img: '/img/carteleria/fastfood.jpg',
    reverse: false,
    text: "A modern location that responds to the latest industry trends needs instant digital communication and interactive screens to take orders. We manage the content broadcast on each screen, segmenting by meal time, store location, special promotions, and more.\n\nIt's an integral solution as we centralize the broadcast of information to thousands of screens.",
  },
  {
    title: 'Outdoor Signage',
    img: '/img/carteleria/exterior.jpg',
    reverse: true,
    text: 'We attract clients outside with interactive digital signage. We showcase your brand in a way that stands out from traditional supports that cannot move or change throughout the day.',
  },
  {
    title: 'Corporate',
    img: '/img/carteleria/corporativo.jpg',
    reverse: false,
    text: "We provide a 360 solution for the challenge of communicating to large communities spread across different locations.\n\nUse screens within your company to keep internal and external communication always updated. For more effective communication, digital screens can be instantly updated at each office.\n\nKeep your clients and company team always informed.",
  },
];
---

<Layout
  title="Digital Signage | CAS Contenidos Advertising"
  description="We believe that interaction through content is the key to improving any type of communication. Integral digital signage solutions for retail, banking, fast food and more."
>

  <section class="bg-black">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">
      <div class="min-h-80 lg:min-h-screen bg-cover" style="background-image: url('/img/carteleria.jpg'); background-position: center left; background-size: cover"></div>
      <div class="flex items-center px-10 md:px-16 py-20">
        <div>
          <a href="/en/que-hacemos" class="inline-flex items-center gap-2 font-['Inter'] text-xs uppercase tracking-wider text-gray-500 hover:text-[#ffb876] transition-colors mb-10">
            <span class="material-symbols-outlined text-sm">arrow_back</span>
            What We Do
          </a>
          <h1 class="font-['Space_Grotesk'] font-black text-5xl md:text-6xl tracking-tighter leading-[0.9] text-[#F69220] mb-10">
            Digital<br />Signage
          </h1>
          <div class="space-y-5 font-['Plus_Jakarta_Sans'] text-white text-base leading-relaxed">
            <p>We believe that interaction through content is the key to improving any type of communication, whether between brands and their consumers, a company and its employees, a corporation and its clients, or any organization with its members.</p>
            <p>The complexity of the action plan to be applied is proportional to the size of the brand or company. The use of communication grows in relation to expansion: the larger it is, the more countries and cities it covers, the more audience or locations it has to get its message across. And this is where the need for an integrated system that provides a solution arises.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#f5f5f5] py-20">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#26c6da] mb-4"><span class="font-light">1</span> . Content Development</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed">We have a team specialized in concept creation, design, and editing that will develop the content to be broadcast on screens.</p>
        </div>
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#F69220] mb-4"><span class="font-light">2</span> . Equipment</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed">We offer the most sophisticated equipment tailored to each need. As specialists, we recommend the best options to create a memorable experience.</p>
        </div>
        <div>
          <h3 class="font-['Space_Grotesk'] font-black text-2xl text-[#EA2227] mb-4"><span class="font-light">3</span> . Content Management Center</h3>
          <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-lg leading-relaxed">Through our Content Manager platform, we centralize all digital content management.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F69220] py-20">
    <div class="max-w-7xl mx-auto px-8">
      <h4 class="font-['Space_Grotesk'] font-black text-2xl text-white mb-12">We have a server that allows us to manage and control what is displayed:</h4>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
        {capabilities.map(c => (
          <div class="bg-white rounded-2xl p-6 flex flex-col gap-4">
            <img src={c.icon} alt="" class="w-14 h-14 object-contain" />
            <p class="font-['Plus_Jakarta_Sans'] text-gray-700 text-sm leading-relaxed">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#f5f5f5] py-12 text-center border-y border-gray-200">
    <div class="max-w-3xl mx-auto px-8">
      <h3 class="font-['Space_Grotesk'] font-black text-2xl text-black tracking-tight">
        We provide an integral solution covering all stages of the process:
      </h3>
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3">
    <div class="bg-[#26c6da] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">lightbulb</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Planning</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">Strategy and creative proposal.<br />Location survey.<br />Communication system development.</p>
    </div>
    <div class="bg-[#F69220] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">polyline</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Implementation</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">Equipment purchase and installation.<br />Content grid setup.<br />Content development and creation.<br />Management from the content center.</p>
    </div>
    <div class="bg-[#EA2227] text-white text-center px-10 py-16">
      <span class="material-symbols-outlined text-5xl mb-6 block">photo_camera</span>
      <h3 class="font-['Space_Grotesk'] font-black text-2xl uppercase tracking-widest mb-4">Control</h3>
      <p class="font-['Plus_Jakarta_Sans'] leading-relaxed">We have a team for control across the entire region.<br />Reporting creation.</p>
    </div>
  </section>

  <section class="bg-[#f5f5f5] py-24">
    <div class="max-w-7xl mx-auto px-8 flex flex-col gap-24">
      {sectors.map(s => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${s.reverse ? 'lg:[direction:rtl]' : ''}`}>
          <div class="lg:[direction:ltr]">
            <img src={s.img} alt={s.title} class="w-full rounded-2xl shadow-xl object-cover" loading="lazy" />
          </div>
          <div class="lg:[direction:ltr]">
            <h3 class="font-['Space_Grotesk'] font-black text-4xl text-[#F69220] tracking-tight mb-6">{s.title}</h3>
            <div class="space-y-4 font-['Plus_Jakarta_Sans'] text-gray-700 text-base leading-relaxed">
              {s.text.split('\n\n').map(p => <p>{p}</p>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-black py-24">
    <div class="max-w-screen-2xl mx-auto px-8">
      <h2 class="font-['Space_Grotesk'] font-black text-5xl md:text-7xl tracking-tight text-white text-center mb-16">
        Success Cases <span class="text-[#F69220]">.</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {casos.map(caso => (
          <a href={`/en/casos/${caso.slug}`} class="group block">
            <div class="relative overflow-hidden aspect-4/3 rounded-2xl mb-4">
              <img alt={getCasoImageAlt(caso)} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src={getCasoImage(caso)} loading="lazy" />
              <div class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <span class="font-['Space_Grotesk'] font-bold text-white text-sm uppercase tracking-widest">View case</span>
              </div>
            </div>
            <h3 class="font-['Space_Grotesk'] font-bold text-lg text-white group-hover:text-[#ffb876] transition-colors tracking-tight" set:html={caso.title.rendered} />
          </a>
        ))}
      </div>
      <div class="text-center mt-16">
        <a href="/en/casos" class="inline-block border border-white/20 text-white font-['Space_Grotesk'] font-black uppercase tracking-widest px-12 py-5 hover:bg-white hover:text-black transition-all duration-300">View all cases</a>
      </div>
    </div>
  </section>

</Layout>
