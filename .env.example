# Copiar este archivo como .env y completar los valores

# URL base del sitio WordPress (sin barra al final)
# Ejemplos:
#   Dominio propio:   https://contenidosad.com
#   Subdominio:       https://cms.cas.com
#   Subcarpeta:       https://cas.com/wp
PUBLIC_WP_URL=https://contenidosad.com

# Sitio WordPress en inglés (instalación separada)
PUBLIC_WP_URL_EN=https://contentad.net
